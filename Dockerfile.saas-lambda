# Dockerfile for the SaaS API Lambda function
FROM public.ecr.aws/lambda/python:3.12

COPY requirements/base.txt /tmp/requirements.txt
RUN pip install --no-cache-dir -r /tmp/requirements.txt && \
    pip install --no-cache-dir mangum boto3 stripe PyJWT[crypto]

COPY aavaaz/ ${LAMBDA_TASK_ROOT}/aavaaz/
COPY pyproject.toml ${LAMBDA_TASK_ROOT}/

RUN pip install --no-cache-dir --no-deps ${LAMBDA_TASK_ROOT}

CMD ["aavaaz.serverless.saas_lambda.handler"]
