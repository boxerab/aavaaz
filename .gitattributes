# Deterministic line endings, independent of any machine's core.autocrlf.
# Text files are normalized to LF in the repo and checked out as LF everywhere.
* text=auto eol=lf

# Binary assets: never apply line-ending conversion.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.wav binary
*.pdf binary
*.woff binary
*.woff2 binary
*.pickle binary
*.doctree binary
*.inv binary
